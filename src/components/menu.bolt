<div id="menu" class="drag">
    <p id="menuTitle"></p>
    <a id="update-btn">
        <i class="fa-solid fa-arrow-rotate-right"></i>
        Instalar Atualização
    </a>
    <div class="menuButtons">
        <i id="menuMin" class="fa-solid fa-window-minimize" onclick="minimizeApp()"></i>
        <i id="menuMax" class="" onclick="maximizeApp()"></i>
        <i id="menuClose" class="fa-solid fa-xmark" onclick="closeApp()"></i>
    </div>
</div>